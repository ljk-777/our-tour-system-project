{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npm run *)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(curl * | bash:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] 执行命令: ' \"$CLAUDE_TOOL_INPUT_COMMAND\" >> .claude/tool-audit.log 2>&1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -q 'algorithms/'; then echo '[hook] 算法文件变更，提醒补充测试用例' >&2; fi"
          }
        ]
      }
    ]
  }
}
